{
  "name": "@minesweeper/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": ".vercel/output/static/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local api/index.ts",
    "seed": "tsx src/seed.ts",
    "build": "esbuild api/index.ts --bundle --platform=node --format=esm --outfile=api/bundle.mjs --external:express --external:cors --external:pg",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@minesweeper/engine": "workspace:*",
    "@minesweeper/types": "workspace:*",
    "@sentry/node": "^10.58.0",
    "@supabase/supabase-js": "^2.49.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "pg": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
